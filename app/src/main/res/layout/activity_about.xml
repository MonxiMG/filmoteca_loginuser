<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AboutActivity">

    <!-- Toolbar superior -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:theme="@style/ThemeOverlay.Material3.ActionBar"
        app:title="@string/app_name"
        app:titleCentered="true" />

    <!-- Contenido desplazable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center"
            android:layout_gravity="center">

            <!-- Imagen del autor -->
            <ImageView
                android:id="@+id/about_image_cd"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:src="@drawable/rosa_azul"
                android:contentDescription="@string/about_image_cd"
                android:layout_marginBottom="24dp" />

            <!-- Texto del autor -->
            <TextView
                android:id="@+id/tvAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_author"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Datos del usuario conectado con Google -->
            <TextView
                android:id="@+id/tvUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuario conectado"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="32dp" />

            <!-- Botón Ir al sitio web -->
            <Button
                android:id="@+id/btnWeb"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btnWeb"
                android:layout_marginBottom="12dp" />

            <!-- Botón Obtener soporte -->
            <Button
                android:id="@+id/btnSupport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btnSupport"
                android:layout_marginBottom="12dp" />

            <!-- Botón Volver -->
            <Button
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btnBack" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
